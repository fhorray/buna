{
  "name": "buna",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/playground dev",
    "build": "bun run --cwd apps/playground build",
    "preview": "bun run --cwd apps/playground preview",
    "deploy": "bun run --cwd apps/playground deploy",
    "cf-typegen": "bun run --cwd apps/playground cf-typegen"
  },
  "devDependencies": {
    "turbo": "^2.6.1"
  }
}
