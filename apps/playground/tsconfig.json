{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "#router": ["./.buna/client-routes.generated.ts"],
      "#hono-app": ["./.buna/hono-routes.generated.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", ".buna", "worker-configuration.d.ts"]
}
