{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext",
      "DOM"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": [
      "vite/client",
      "hono/jsx"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
  }
}
