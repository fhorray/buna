{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ],
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "allowImportingTsExtensions":true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "#router": ["./.buna/client-routes.generated.ts"],
      "#hono-app": ["./.buna/hono-routes.generated.tsx"],
      "@/*": ["./*"] 
    },
  },
}